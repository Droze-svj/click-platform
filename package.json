{
  "name": "click",
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "description": "Click - Transform long-form content into social-ready formats with AI-powered tools",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently -k \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && pnpm run dev -- --port 3010",
    "dev:client:turbo": "cd client && pnpm run dev:turbo",
    "build": "npm run prisma:generate && cd client && NODE_OPTIONS='--max-old-space-size=2048' npm run build",
    "start": "node server/index.js",
    "start:prod": "NODE_OPTIONS='--max-old-space-size=2048' node server/index.js",
    "start:server": "node --max-old-space-size=2048 server/index.js",
    "start:client": "cd client && pnpm start",
    "prisma:generate": "NODE_OPTIONS='--max-old-space-size=2048' npx --no-install prisma generate --schema=prisma/schema.prisma",
    "install:all": "pnpm install && cd client && pnpm install",
    "seed:testers": "node scripts/seed-test-users.js",
    "preflight": "node scripts/preflight.js",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration --forceExit",
    "test:e2e": "jest --selectProjects e2e --forceExit",
    "test:e2e:browser": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:accessibility": "playwright test tests/e2e/accessibility.spec.js",
    "test:e2e:performance": "playwright test tests/e2e/performance.spec.js",
    "test:e2e:visual": "playwright test tests/e2e/visual-regression.spec.js",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:performance": "jest --selectProjects performance",
    "test:security": "jest --selectProjects security --forceExit",
    "deploy:production": "node scripts/production-deploy.js",
    "monitor:production": "node scripts/production-monitoring.js",
    "performance:regression": "node scripts/performance-regression-check.js",
    "backup:production": "node scripts/production-backup.js",
    "analytics:start": "node scripts/production-analytics.js",
    "operations:dashboard": "node scripts/production-operations.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint server/utils/ownership.js server/services/trendComposer.js server/services/creatorPerformanceService.js server/routes/marketingIntelligence.js server/routes/userStyleProfile.js server/routes/ingest.js",
    "lint:full": "eslint server/**/*.js",
    "lint:fix": "eslint server/**/*.js --fix",
    "setup:env": "bash scripts/setup-env.sh",
    "validate:env": "node scripts/validate-env.js",
    "validate:production": "node scripts/validate-production-env.js",
    "verify:production:env": "node scripts/verify-production-env.js",
    "verify:phase0": "node scripts/verify-phase0.js",
    "verify:production:build": "bash scripts/test-production-build.sh",
    "verify:security": "node scripts/verify-security.js",
    "verify:production": "bash scripts/run-production-verification.sh",
    "deploy:build": "bash scripts/deploy-production.sh",
    "deploy:quick": "bash scripts/quick-deploy.sh",
    "deploy:migrate": "node scripts/migrate-database.js",
    "deploy:backup": "node scripts/backup-database.js",
    "deploy:verify": "bash scripts/verify-deployment.sh",
    "deploy:setup-ssl": "sudo bash scripts/setup-ssl.sh",
    "deploy:setup-monitoring": "sudo bash scripts/setup-monitoring.sh",
    "setup:staging": "bash scripts/setup-staging.sh",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "start:staging": "NODE_ENV=staging PORT=5002 node server/index.js",
    "dev:staging": "NODE_ENV=staging concurrently \"npm run dev:server:staging\" \"npm run dev:client\"",
    "dev:server:staging": "NODE_ENV=staging PORT=5002 nodemon server/index.js",
    "docker:staging": "docker-compose -f docker-compose.staging.yml up -d",
    "docker:staging:down": "docker-compose -f docker-compose.staging.yml down",
    "test:integrations": "node scripts/test-integrations.js",
    "quick-start": "bash scripts/quick-start.sh",
    "verify:oauth": "node scripts/verify-oauth-comprehensive.js",
    "verify:oauth:staging": "node scripts/verify-oauth-comprehensive.js --env=staging",
    "verify:oauth:production": "node scripts/verify-oauth-comprehensive.js --env=production",
    "prepare:production": "bash scripts/prepare-production-deployment.sh",
    "get-free-ai-keys": "bash scripts/get-free-ai-api-keys.sh",
    "validate:free-ai-keys": "node scripts/validate-free-ai-keys.js",
    "test:critical": "playwright test tests/e2e/critical-flows.spec.js",
    "test:oauth": "node scripts/test-oauth-integrations.js",
    "test:oauth:all": "node scripts/test-oauth-integrations.js all",
    "verify:oauth:structure": "node scripts/verify-oauth-structure.js",
    "setup:production": "bash scripts/setup-production-interactive.sh",
    "setup:best-practices": "bash scripts/setup-best-practices.sh",
    "deploy:best-practices": "bash scripts/deploy-best-practices.sh",
    "setup:free-tier": "bash scripts/setup-free-tier.sh",
    "setup:railway": "bash scripts/setup-railway.sh",
    "setup:render": "bash scripts/setup-render.sh",
    "sync": "./sync-to-github.sh",
    "sync:pull": "git pull origin main",
    "roadmap": "open -a Cursor ROADMAP_STATUS.md 2>/dev/null || open ROADMAP_STATUS.md",
    "assign": "node scripts/assign.js"
  },
  "keywords": [
    "content",
    "creator",
    "social-media",
    "click",
    "video-editing",
    "ai-content"
  ],
  "author": "",
  "license": "MIT",
