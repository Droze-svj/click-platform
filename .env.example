# Click - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ============================================
# Database
# ============================================
MONGODB_URI=mongodb://localhost:27017/click

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================
# Google AI / Gemini (for AI features)
# ============================================
# Get your API key from: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# ============================================
# File Upload Limits
# ============================================
MAX_VIDEO_FILE_SIZE=524288000
MAX_MUSIC_FILE_SIZE=52428800
MAX_FILE_SIZE=1073741824

# ============================================
# Signed Media (private /uploads access control)
# ============================================
# The /uploads tree is served statically and the app is Bearer-only, so media is
# delivered as short-lived HMAC-signed capability URLs. The API always SIGNS the
# URLs it returns (global signer); this flag turns on ENFORCEMENT at the static
# layer. Leave OFF until the staging cutover is verified, then set true in prod.
REQUIRE_SIGNED_MEDIA=false
# Dedicated signing secret. STRONGLY recommended to set this (32+ random bytes);
# if unset it falls back to JWT_SECRET. Must be identical across all app instances.
# MEDIA_URL_SECRET=change-me-to-a-long-random-string
# Signed-URL lifetime in seconds (default 86400 = 24h). Longer = fewer re-signs,
# but a leaked URL is valid longer.
# MEDIA_URL_TTL_SEC=86400
# Comma-separated /uploads sub-prefixes that bypass the signature (truly public
# assets only — e.g. fonts). Default: fonts/
# PUBLIC_MEDIA_PREFIXES=fonts/

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Redis (optional for local - workers work without it)
# ============================================
# REDIS_URL=redis://localhost:6379

# ============================================
# Cache Configuration
# ============================================
CACHE_MAX_ENTRIES=1000
CACHE_TTL_SECONDS=300

# ============================================
# Request Timeout
# ============================================
REQUEST_TIMEOUT=30000

# ============================================
# Sentry Error Tracking (Backend)
# ============================================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_RELEASE=click@1.0.0
SENTRY_ORG=
SENTRY_PROJECT=

# ============================================
# Sentry Error Tracking (Frontend - Next.js)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_RELEASE=click-client@1.0.0

# ============================================
# Cloud Storage (use S3 or Cloudinary for production scale)
# ============================================
# Option A: AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_ACL=private
AWS_CLOUDFRONT_URL=

# Option B: Cloudinary (if set, takes precedence over S3 for uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# Twitter/X OAuth
# ============================================
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ============================================
# LinkedIn OAuth
# ============================================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ============================================
# Facebook/Instagram OAuth
# ============================================
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ============================================
# Stock Assets (Music, Images, B-Roll)
# ============================================
# PEXELS_API_KEY=your-pexels-api-key  # Optional: enables unlimited B-roll search via Pexels

# ============================================
# WHOP Integration (Optional)
# ============================================
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=

# Whop product IDs — paste each plan's product_id from your Whop dashboard.
# Read by server/services/whopWebhookService.js to map an inbound payment
# event to the right plan ID. Without these, the webhook still records the
# subscription as "active" but can't pick a tier (defaults to current/free).
WHOP_PRODUCT_ID_CREATOR_MONTHLY=
WHOP_PRODUCT_ID_CREATOR_YEARLY=
WHOP_PRODUCT_ID_PRO_MONTHLY=
WHOP_PRODUCT_ID_PRO_YEARLY=
WHOP_PRODUCT_ID_AGENCY_MONTHLY=
WHOP_PRODUCT_ID_AGENCY_YEARLY=

# ============================================
# Whop hosted checkout URLs (public, client-side)
# ============================================
# Paste each plan's hosted checkout URL from your Whop dashboard.
# Read by client/lib/plans.ts and surface on the public landing pricing
# section + the in-app billing page. Empty values fall back to
# /register?plan=<id> with a "checkout coming soon" toast.
NEXT_PUBLIC_WHOP_URL_CREATOR_MONTHLY=
NEXT_PUBLIC_WHOP_URL_CREATOR_YEARLY=
NEXT_PUBLIC_WHOP_URL_PRO_MONTHLY=
NEXT_PUBLIC_WHOP_URL_PRO_YEARLY=
NEXT_PUBLIC_WHOP_URL_AGENCY_MONTHLY=
NEXT_PUBLIC_WHOP_URL_AGENCY_YEARLY=

# ============================================
# AI Router — multi-LLM fallback chain
# ============================================
# server/utils/aiRouter.js walks Gemini -> OpenAI -> Anthropic -> deterministic
# fallback. Set whichever providers you want active. Without OPENAI / ANTHROPIC,
# AI features still work via Gemini + heuristic fallback when Gemini quota dies.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Set to 'true' to disable the deterministic fallback and let aiCall() throw
# when every provider fails. Useful for staging assertions, NOT prod.
AI_ROUTER_DISABLE_FALLBACK=false

# ============================================
# Stock footage — Pexels API for Magic B-Roll
# ============================================
# server/services/stockFootageService.js calls Pexels to fill B-roll keyword
# searches with real clips. Without this key, magicBRoll falls back to a
# Coverr placeholder URL — usable in dev, not great in prod.
PEXELS_API_KEY=

# ============================================
# Email verification — staging / tester opt-out
# ============================================
# When set to "true", new /api/auth/register users are marked
# email_verified: true immediately and the middleware skips the 403
# "Email verification required" gate. Use this in local + staging
# environments where SendGrid isn't configured so testers don't get
# locked out of the dashboard with no way to verify.
#
# LEAVE UNSET IN PRODUCTION — paying customers should verify their
# email like every other real service.
AUTO_VERIFY_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL AI FEATURE INTEGRATIONS (external, paid — leave unset to keep them off)
#
# Each feature returns an honest "coming soon" until its key(s) are set. After
# adding keys in your host's env store and redeploying, verify wiring via the
# boot log ("🤖 AI feature wiring …") or GET /api/admin/ai-features (admin-gated).
# Setting only SOME of a required pair is flagged as "misconfigured" (loud warn) —
# a half-set integration otherwise silently stays off and reads as a bad key.
# ─────────────────────────────────────────────────────────────────────────────

# Voice dubbing / localization (ElevenLabs). DEFAULT_VOICE_ID is optional.
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

# AI avatar / digital twin — set EITHER HeyGen OR Sora (key + gateway URL).
HEYGEN_API_KEY=
SORA_API_KEY=
SORA_GATEWAY_URL=

# Eye-contact fix (gaze redirection provider, e.g. Sieve / NVIDIA Maxine).
EYE_CONTACT_API_URL=
EYE_CONTACT_API_KEY=

# Outpainting — temporal object removal (SAM 2 + inpainting provider).
OBJECT_REMOVAL_API_URL=
OBJECT_REMOVAL_API_KEY=

# Outpainting — generative background replacement (segmentation + diffusion).
BG_REPLACE_API_URL=
BG_REPLACE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# RENDER PERFORMANCE
# Opt in to hardware-accelerated video encoding (NVENC on NVIDIA hosts,
# VideoToolbox on Apple silicon). Safe no-op if the host's ffmpeg lacks it —
# the render falls back to software encoding automatically.
# ─────────────────────────────────────────────────────────────────────────────
RENDER_HW_ACCEL=
